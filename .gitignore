# ==================================================
# Python Bytecode & Cache
# ==================================================
__pycache__/
**/__pycache__/
*.py[cod]
*.so

# ==================================================
# Virtual Environments
# ==================================================
.venv/
venv/
ENV/

# ==================================================
# Environment Variables
# ==================================================
.env
.env.*

# ==================================================
# Jupyter Notebooks
# ==================================================
.ipynb_checkpoints/

# ==================================================
# IDE & Editor Files
# ==================================================
.vscode/
.idea/

# ==================================================
# Operating System Files
# ==================================================
.DS_Store
Thumbs.db

# ==================================================
# Dataset Storage
# Keep folder structure but ignore large datasets
# ==================================================
data/**/*

# Preserve empty directories
!data/**/.gitkeep

# ==================================================
# Machine Learning Artifacts
# Large generated files should not be versioned
# ==================================================
ml/artifacts/models/
ml/artifacts/cache/
ml/artifacts/history/

*.h5
#*.keras
*.pkl

# ==================================================
# Training Outputs & Reports
# Generated during evaluation/training
# ==================================================
ml/reports/*.txt
ml/reports/*.json

# ==================================================
# Airflow Local Environment
# ==================================================
airflow.db
airflow/*.db

airflow/logs/
airflow/logs/**/*

logs/

airflow.cfg
airflow/airflow.cfg
airflow/webserver_config.py

# ==================================================
# Testing & Coverage
# ==================================================
.coverage
htmlcov/
.pytest_cache/

# ==================================================
# Docker & Runtime Logs
# ==================================================
*.log